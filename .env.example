# Core
TZ=Asia/Singapore

# Source control
INGEST_SOURCES=rss
FEEDS_FILE=./feeds.txt
MAX_ITEMS_PER_FEED=50

# Output
SQLITE_PATH=./data/daily-blog.db
OUTPUT_JSONL=./data/mentions.jsonl

# Rules engine / scoring
RULES_ENGINE_CONFIG=./config/rules-engine.json
DAILY_BOARD_PATH=./data/daily_board.md

# Editorial outputs
MODEL_ROUTING_CONFIG=./config/model-routing.json
PIPELINE_TIMEOUTS_PATH=./config/pipeline-timeouts.json
PROMPTS_CONFIG=./config/prompts.json
RESEARCH_PACK_PATH=./data/research_pack.json
TOP_OUTLINES_PATH=./data/top_outlines.md

# Pipeline retries
PIPELINE_RETRIES=2
PIPELINE_STAGE_TIMEOUT_SECONDS=300
# Example JSON object for per-stage timeout overrides.
# PIPELINE_STAGE_TIMEOUTS={"enrich_topics":420,"generate_editorial":420}
# Example comma list or JSON array of stage names to skip.
# PIPELINE_SKIP_STAGES=ingest,score

# Extraction/topic curation
EXTRACT_MAX_MENTIONS=300
FORCE_TOPIC_RECURATE=0
TOPIC_CURATOR_BATCH_SIZE=20

# Enrichment fetch and discovery
ENRICH_DISCOVER_LIMIT=10
ENRICH_FETCH_BACKOFF_SECONDS=0.6
ENRICH_FETCH_RETRIES=2
ENRICH_FETCH_TIMEOUT_SECONDS=10
ENRICH_FETCH_USER_AGENT="Mozilla/5.0 (compatible; daily-blog-enrichment/0.2; +https://localhost)"
ENRICH_MAX_KNOWN_CLAIM_URLS=24
ENRICH_MAX_TOPICS=0
ENRICH_SKIP_MODEL=0

# Discussion harvesting
ENRICH_DISCUSSION_MAX_COMMENTS=20
ENRICH_DISCUSSION_MAX_THREADS=3
ENRICH_DISCUSSION_TIMEOUT_SECONDS=12

# Editorial generation
EDITORIAL_STATIC_ONLY=0
