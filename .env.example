# ──────────────────────────────────────────────
# Core storage paths
# ──────────────────────────────────────────────

# What it controls: path to the main SQLite database
# When to change: point to an existing DB or a different location for multiple environments
SQLITE_PATH=./data/daily-blog.db

# What it controls: file listing RSS/Atom feed URLs to ingest, one per line
# When to change: change to a custom feed list path; defaults to feeds.txt in project root
INGEST_FEEDS_FILE=./feeds.txt

# What it controls: JSONL output file written by ingest_rss.py with raw mention records
# When to change: rarely; only if you need the JSONL at a different location
INGEST_OUTPUT_JSONL=./data/mentions.jsonl

# What it controls: markdown file written by score_rss.py with today's daily board summary
# When to change: change output path for the board, e.g. to serve it from a different directory
SCORE_BOARD_PATH=./data/daily_board.md

# What it controls: markdown file with top editorial outlines, written by generate_editorial.py
# When to change: point to a different location if the editorial output needs to be served elsewhere
EDITORIAL_OUTLINES_PATH=./data/top_outlines.md

# What it controls: JSON file containing the full research pack (evidence + sources per topic)
# When to change: change if the research pack output needs to live at a different path
EDITORIAL_RESEARCH_PACK_PATH=./data/research_pack.json

# What it controls: directory under which per-run dossier subdirectories are created
# When to change: redirect dossier output to a mounted volume or a different data directory
EDITORIAL_DOSSIER_DIR=./data/candidates

# ──────────────────────────────────────────────
# Config files
# ──────────────────────────────────────────────

# What it controls: path to the rules-engine JSON that drives scoring and claim filtering
# When to change: point to a custom rules file for a different scoring profile
RULES_ENGINE_CONFIG=./config/rules-engine.json

# What it controls: path to model routing JSON that maps pipeline stages to primary/fallback models
# When to change: swap to a different routing file for a different model configuration
MODEL_ROUTING_CONFIG=./config/model-routing.json

# What it controls: path to prompts JSON used by all LLM call sites
# When to change: point to a custom prompts file to experiment with different prompt templates
PROMPTS_CONFIG=./config/prompts.json

# What it controls: path to JSON file with per-stage timeout overrides
# When to change: point to a custom timeouts file; values inside override PIPELINE_STAGE_TIMEOUT_SECONDS
PIPELINE_TIMEOUTS_PATH=./config/pipeline-timeouts.json

# ──────────────────────────────────────────────
# Ingest
# ──────────────────────────────────────────────

# What it controls: maximum number of items fetched per feed per ingest run
# When to change: lower for faster CI runs; raise for more thorough ingestion
# Units: integer count
INGEST_MAX_ITEMS_PER_FEED=50

# ──────────────────────────────────────────────
# Pipeline orchestration
# ──────────────────────────────────────────────

# What it controls: number of times each pipeline stage retries on failure before giving up
# When to change: set to 0 for fast-fail debugging; raise to 3 for production resilience
PIPELINE_RETRIES=2

# What it controls: default timeout for each pipeline stage subprocess
# When to change: raise for slow models (e.g. Ollama locally); lower for CI speed
# Units: seconds
PIPELINE_STAGE_TIMEOUT_SECONDS=300

# What it controls: per-stage timeout overrides that take precedence over PIPELINE_STAGE_TIMEOUT_SECONDS
# When to change: tune individual stages without affecting the global default
# Format: JSON object, e.g. {"lift_topics":180,"generate_editorial":240}
PIPELINE_STAGE_TIMEOUTS=

# What it controls: stages to skip in the current pipeline run
# When to change: skip expensive stages when re-running from a checkpoint
# Format: JSON array or CSV, e.g. ["enrich_topics"] or enrich_topics,generate_editorial
PIPELINE_SKIP_STAGES=

# What it controls: whether subprocess stdout is streamed live to the terminal
# When to change: set to 0 to suppress live output and only show on failure
# Values: 1=stream (default), 0=buffer
PIPELINE_STREAM_SUBPROCESS_OUTPUT=1

# What it controls: enables structured TRACE-level log events for pipeline debugging
# When to change: set to 1 when diagnosing timing or routing issues
# Values: 1=enabled, 0=disabled (default)
PIPELINE_TRACE=0

# ──────────────────────────────────────────────
# Extract claims
# ──────────────────────────────────────────────

# What it controls: maximum number of mentions fed into the claim extraction stage
# When to change: lower for faster iteration; raise to process more content per run
EXTRACT_MAX_MENTIONS=300

# What it controls: how often (every N mentions) a progress line is printed during extraction
# When to change: lower for more frequent feedback; raise to reduce log noise
EXTRACT_PROGRESS_EVERY=25

# ──────────────────────────────────────────────
# Topic lifting
# ──────────────────────────────────────────────

# What it controls: number of claims sent to the topic-lifter model per batch
# When to change: lower to 1 for Ollama (avoids context overflow); raise for faster cloud runs
# Default: automatic (1 for ollama/*, 10 otherwise)
TOPIC_LIFTER_BATCH_SIZE=

# What it controls: seconds subtracted from the stage timeout when deciding if a batch timed out
# When to change: increase if the topic lifter occasionally exceeds the stage timeout
# Units: seconds
TOPIC_LIFTER_TIMEOUT_BUFFER_SECONDS=30

# What it controls: whether a topic lifter batch timeout aborts the whole stage immediately
# When to change: set to 0 to continue on timeout (partial results accepted)
# Values: 1=fail fast (default), 0=continue
TOPIC_LIFTER_FAILFAST_ON_TIMEOUT=1

# ──────────────────────────────────────────────
# Topic normalization / curation
# ──────────────────────────────────────────────

# What it controls: number of topics processed per curator model batch
# When to change: lower for Ollama; raise for faster cloud processing
TOPIC_CURATOR_BATCH_SIZE=50

# What it controls: minimum topic_confidence score for a topic to reach the editorial stage
# When to change: lower to include more speculative topics; raise to be more selective
# Units: float 0.0–1.0
TOPIC_CONFIDENCE_THRESHOLD=0.3

# What it controls: forces all topics to be re-curated, even those already normalized
# When to change: set to 1 after changing curation prompts or rules to re-process everything
# Values: 1=re-curate all, 0=skip already-curated (default)
FORCE_TOPIC_RECURATION=0

# ──────────────────────────────────────────────
# Enrichment
# ──────────────────────────────────────────────

# What it controls: skips the model-based source discovery step and returns empty sources
# When to change: set to 1 in CI or offline environments to speed up tests
# Values: 1=skip model, 0=use model (default)
ENRICH_SKIP_MODEL=0

# What it controls: HTTP timeout for each fetch request during source enrichment
# When to change: raise for slow or rate-limited sources; lower for faster CI runs
# Units: seconds
ENRICH_FETCH_TIMEOUT_SECONDS=10

# What it controls: number of retries for a failed source fetch
# When to change: raise for flaky networks; set to 0 to fail immediately
ENRICH_FETCH_RETRIES=2

# What it controls: base delay between fetch retries (exponential backoff multiplier)
# When to change: raise to be gentler on rate-limited sources
# Units: seconds
ENRICH_FETCH_BACKOFF_SECONDS=0.6

# What it controls: User-Agent header sent with enrichment HTTP requests
# When to change: rarely; only if a specific site blocks the default agent
ENRICH_FETCH_USER_AGENT=Mozilla/5.0 (compatible; daily-blog-enrichment/0.2; +https://localhost)

# What it controls: maximum number of sources discovered per topic by the model
# When to change: raise for more source diversity; lower to reduce API cost
ENRICH_DISCOVER_LIMIT=10

# What it controls: maximum number of known source URLs considered when filtering duplicates
# When to change: raise if topics are large and have many existing sources
ENRICH_MAX_KNOWN_CLAIM_URLS=24

# What it controls: maximum number of topics enriched per run (0 = all topics)
# When to change: set to a low number (e.g. 5) to limit API spend during testing
ENRICH_MAX_TOPICS=0

# What it controls: minimum number of distinct source domains required for a topic to pass evidence quality
# When to change: lower to accept single-source topics; raise for stricter editorial standards
ENRICH_MIN_DOMAIN_DIVERSITY=3

# What it controls: maximum number of sources allowed from a single domain per topic
# When to change: raise to allow more content from trusted outlets; lower for diversity
ENRICH_MAX_PER_DOMAIN=3

# What it controls: minimum number of credible sources required for a topic to reach editorial
# When to change: lower for less restrictive evidence gate; raise for higher quality bar
ENRICH_MIN_CREDIBLE_COUNT=3

# What it controls: how often (every N topics) a progress line is printed during enrichment
# When to change: lower for more frequent feedback; raise to reduce log noise
ENRICH_PROGRESS_EVERY=1

# What it controls: which search backend is used for source discovery (ddgs = DuckDuckGo)
# When to change: switch to "searxng" to use a self-hosted SearXNG instance
# Values: ddgs (default), searxng
ENRICH_SEARCH_BACKEND=ddgs

# What it controls: base URL for the SearXNG instance used when ENRICH_SEARCH_BACKEND=searxng
# When to change: point to your self-hosted SearXNG URL
SEARXNG_BASE_URL=http://localhost:8888

# What it controls: comma-separated list of search engines SearXNG uses for queries
# When to change: remove engines that are rate-limited or unreliable in your environment
SEARXNG_ENGINES=google,bing,duckduckgo,brave

# ──────────────────────────────────────────────
# Editorial
# ──────────────────────────────────────────────

# What it controls: whether the "misc" catch-all topic is included in editorial generation
# When to change: set to 1 to include miscellaneous topics; 0 to skip them (default)
# Values: 1=include misc, 0=skip misc (default)
EDITORIAL_INCLUDE_MISC=0

# What it controls: skips LLM calls and uses static template-based editorial packages instead
# When to change: set to 1 for rapid testing without API calls
# Values: 1=static only, 0=use model (default)
EDITORIAL_STATIC_ONLY=0

# ──────────────────────────────────────────────
# Model provider timeouts
# ──────────────────────────────────────────────

# What it controls: timeout for Ollama HTTP API calls
# When to change: raise for large local models that are slow to respond
# Units: seconds
OLLAMA_TIMEOUT_SECONDS=75

# What it controls: timeout for Gemini API (google-genai SDK) calls
# When to change: raise if Gemini responses consistently hit the limit
# Units: seconds
GEMINI_TIMEOUT_SECONDS=45

# What it controls: timeout for gemini CLI subprocess calls
# When to change: raise for slow CLI environments
# Units: seconds
GEMINI_CLI_TIMEOUT_SECONDS=30

# What it controls: timeout for generic model CLI subprocess calls (opencode, openclaw)
# When to change: raise for slow or large model CLI tools
# Units: seconds
MODEL_CLI_TIMEOUT_SECONDS=60

# ──────────────────────────────────────────────
# Gemini / Google auth
# ──────────────────────────────────────────────

# What it controls: Google API key for Gemini (google-genai SDK)
# When to change: set to your key from https://aistudio.google.com/apikey
# Security: never commit this value; keep it in .env only
GOOGLE_API_KEY=

# What it controls: switches Gemini authentication to Vertex AI (gcloud ADC) instead of API key
# When to change: set to 1 in GCP environments using service account credentials
# Values: 1=Vertex AI, 0=API key (default)
GOOGLE_GENAI_USE_VERTEXAI=0

# What it controls: GCP project ID used when GOOGLE_GENAI_USE_VERTEXAI=1
# When to change: set to your GCP project ID
GOOGLE_CLOUD_PROJECT=

# What it controls: GCP region for Vertex AI Gemini API calls
# When to change: change to a closer region to reduce latency
GOOGLE_CLOUD_LOCATION=us-central1

# ──────────────────────────────────────────────
# Internal runtime vars (set by pipeline; do not set manually)
# ──────────────────────────────────────────────
RUN_ID=
PIPELINE_RUN_ID=
MODEL_NAME=
MODEL_ROUTE=
MODEL_ROUTING_STAGE=
STAGE_TIMEOUT_SECONDS=
